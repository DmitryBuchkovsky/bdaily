{
  "name": "@bdaily/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --coverage",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@bdaily/shared": "workspace:*",
    "@fastify/cors": "^10",
    "@fastify/jwt": "^9",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.0.0",
    "@prisma/client": "^6",
    "bcryptjs": "^2",
    "fastify": "^5",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.2",
    "pino-pretty": "^13.1.3",
    "sanitize-html": "^2.17.1",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2",
    "@types/node": "^22",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/sanitize-html": "^2.16.1",
    "prisma": "^6",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
